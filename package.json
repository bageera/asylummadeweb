{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build",
        "dev": "vite",
        "lint": "eslint resources/js --ext .js,.vue --fix",
        "lint:check": "eslint resources/js --ext .js,.vue",
        "format": "prettier --write \"resources/**/*.{js,vue,css,blade.php}\"",
        "format:check": "prettier --check \"resources/**/*.{js,vue,css,blade.php}\""
    },
    "devDependencies": {
        "@tailwindcss/vite": "^4.0.0",
        "axios": "^1.11.0",
        "concurrently": "^9.0.1",
        "eslint": "^8.57.0",
        "eslint-config-prettier": "^9.1.0",
        "eslint-plugin-import": "^2.29.1",
        "eslint-plugin-prettier": "^5.1.3",
        "laravel-vite-plugin": "^2.0.0",
        "prettier": "^3.2.5",
        "tailwindcss": "^4.0.0",
        "vite": "^7.0.7"
    }
}
